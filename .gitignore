sbom-npm.cdx.json
src-tauri/*.cdx.json

# Rust/Tauri build artifacts + generated schemas
/src-tauri/target/
/src-tauri/gen/

# Bundled Node sidecar binary (staged by scripts/stage-node.ps1 before `tauri build`; not source)
/src-tauri/binaries/

# IDE workspace
*.code-workspace

# Test outputs
/test-results/
/playwright-report/

# VitePress build output
docs/.vitepress/dist
docs/.vitepress/cache

# Local-only company template fixture (IP-stripped shell; not committed)
tests/fixtures/templates/CX_sample_MSGothic.pptx

# Company source templates (.potx) — real IP, kept LOCAL only, never committed.
# Some tests reference them via skipIf(existsSync) so they simply skip in CI.
tests/fixtures/templates/*.potx

# Signing keys / secrets — NEVER commit. Windows signing uses the SignPath HSM (the key never
# reaches this repo or CI); a future updater key + any local secrets stay out of git. Belt-and-
# suspenders: CI also runs gitleaks (see .github/workflows/security.yml). Cf. CODE_SIGNING_POLICY.md.
*.pem
*.key
*.pfx
*.p12
*.jks
*.keystore
*.pgp
*.asc
*.sec
minisign.key
*.minisign
.env
.env.local
.env.*.local

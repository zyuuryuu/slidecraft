{
  "name": "slidecraft",
  "private": true,
  "version": "0.4.1",
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "prepare": "node scripts/setup-hooks.mjs",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "parse-audit": "npx tsx scripts/parse-audit.ts",
    "tauri": "tauri",
    "tauri:wsl": "bash scripts/tauri-dev-wsl.sh",
    "typecheck:mcp": "tsc -p tsconfig.mcp.json",
    "build:mcp": "esbuild src/mcp/cli.ts --bundle --platform=node --format=esm --outfile=dist/mcp/cli.js --packages=external --banner:js='#!/usr/bin/env node'",
    "build:mcp:bundled": "esbuild src/mcp/cli.ts --bundle --platform=node --format=cjs --target=node20 --outfile=dist/mcp/cli.cjs",
    "build:host": "esbuild src/mcp/host-main.ts --bundle --platform=node --format=cjs --target=node20 --outfile=dist/mcp/host.cjs",
    "stage-node": "node scripts/stage-node.mjs",
    "stage-llamafile": "node scripts/stage-llamafile.mjs",
    "build:desktop": "npm run stage-node && npm run stage-llamafile && npm run tauri build -- --config src-tauri/tauri.bundle.conf.json",
    "sbom": "npm sbom --sbom-format cyclonedx --omit dev > sbom-npm.cdx.json",
    "version:check": "node scripts/bump-version.mjs --check",
    "version:set": "node scripts/bump-version.mjs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.3",
    "@codemirror/autocomplete": "^6.20.3",
    "@codemirror/commands": "^6.10.4",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.1",
    "@codemirror/lang-yaml": "^6.1.3",
    "@codemirror/language": "^6.12.4",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@tailwindcss/vite": "^4.3.3",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.2",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-http": "^2.5.9",
    "@tauri-apps/plugin-opener": "^2.5.4",
    "harfbuzzjs": "^0.10.3",
    "i18next": "^26.3.6",
    "js-yaml": "^5.2.1",
    "jszip": "^3.10.1",
    "mermaid": "^11.13.0",
    "openai": "^6.48.0",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.10",
    "tailwindcss": "^4.2.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tauri-apps/cli": "^2.11.4",
    "@types/js-yaml": "^4.0.9",
    "@types/jszip": "^3.4.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.7.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vitepress": "^2.0.0-alpha.18",
    "vitest": "^4.1.10"
  }
}

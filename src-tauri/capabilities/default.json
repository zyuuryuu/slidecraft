{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Core + native dialog + scoped fs (dialog-picked paths + app-local masters/) for the main window.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-read-file",
    "fs:allow-write-file",
    "fs:allow-write-text-file",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$APPLOCALDATA/masters" },
        { "path": "$APPLOCALDATA/masters/**" }
      ]
    },
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://localhost:*/*" },
        { "url": "http://127.0.0.1:*/*" },
        { "url": "https://**" }
      ]
    },
    {
      "identifier": "opener:allow-open-url",
      "allow": [{ "url": "https://zyuuryuu.github.io/**" }]
    }
  ]
}

{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SlideCraft",
  "version": "0.2.2",
  "identifier": "com.slidecraft.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && npm run build:host && npm run build:mcp:bundled"
  },
  "app": {
    "windows": [
      {
        "title": "SlideCraft",
        "width": 1280,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": {
        "default-src": "'self'",
        "connect-src": "'self' ipc: http://ipc.localhost http://localhost:11434 http://127.0.0.1:* https://api.anthropic.com https://api.openai.com https://openrouter.ai",
        "img-src": "'self' data: blob: asset: http://asset.localhost",
        "style-src": "'self' 'unsafe-inline'",
        "font-src": "'self' data:",
        "script-src": "'self'"
      },
      "devCsp": {
        "default-src": "'self'",
        "connect-src": "'self' ipc: http://ipc.localhost ws://localhost:5173 http://localhost:5173 http://localhost:11434 http://127.0.0.1:* https://api.anthropic.com https://api.openai.com https://openrouter.ai",
        "img-src": "'self' data: blob: asset: http://asset.localhost",
        "style-src": "'self' 'unsafe-inline'",
        "font-src": "'self' data:",
        "script-src": "'self' 'unsafe-eval'"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "license": "Apache-2.0",
    "licenseFile": "../LICENSE",
    "copyright": "Copyright © 2026 The SlideCraft Authors — Apache-2.0",
    "publisher": "The SlideCraft Authors",
    "fileAssociations": [
      {
        "ext": ["scft"],
        "name": "SlideCraft Project",
        "description": "SlideCraft project (deck + template)",
        "role": "Editor",
        "mimeType": "application/x-slidecraft"
      }
    ],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
